/etc/nftables.conf
---------------
#!/usr/sbin/nft -f

flush ruleset

table inet filter {
    chain forward {
        type filter hook forward priority 0; policy drop;

        # 1. Cho phép traffic phản hồi quay về (BẮT BUỘC)
        ct state established,related accept

        # 2. Internet (.167.x) vào Nginx (.40) qua card dải 167
        # Thay "enp0s8" bằng tên card mạng dải 167 trên Firewall của bạn
        iifname "enp0s8" ip daddr 192.168.168.40 tcp dport { 80, 443 } accept

        # 3. Cho phép Ping xuyên qua Firewall (Để test máy Internet -> Nginx)
        iifname "enp0s8" icmp type echo-request accept

        # 4. Cho phép DMZ/LAN đi ra Internet
        ip saddr { 192.168.168.0/24, 192.168.169.0/24 } oifname "enp0s3" accept
    }

    chain input {
        type filter hook input priority 0; policy drop;
        
        # Cho phép Ping TRỰC TIẾP vào Firewall để kiểm tra kết nối vật lý
        iifname "enp0s8" icmp type echo-request accept
        
        # Cho phép SSH và Loopback
        tcp dport 22 accept
        iif lo accept
        ct state established,related accept
    }
}

table ip nat {
    chain prerouting {
        type nat hook prerouting priority dstnat;
        # DNAT từ ngoài vào Nginx (.40)
        iifname "enp0s8" tcp dport { 80, 443 } dnat to 192.168.168.40
    }

    chain postrouting {
        type nat hook postrouting priority srcnat;
        oifname "enp0s3" masquerade
    }
}
